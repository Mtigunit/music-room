generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ======================================================
// ENUMS
// ======================================================
enum PlaybackStatus {
  PLAYING
  PAUSED
}

enum TrackStatus {
  QUEUED
  PLAYING
  ENDED
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum PlaylistEditLicense {
  OPEN
  RESTRICTED
}

enum Tags {
  POP
  HIP_HOP
  RNB
  ROCK
  JAZZ
  CLASSICAL
  ELECTRONIC
  COUNTRY
  CHILL
  WORKOUT
  PARTY
  FOCUS
  ACOUSTIC
}

enum SubscriptionTier {
  BASIC
  PREMIUM
}

enum NotificationType {
  FOLLOW
  EVENT_INVITE
  EVENT_START
}

// ======================================================
// 1. USER MANAGEMENT & SOCIAL
// ======================================================
model User {
  id       String @id @default(uuid())
  email    String @unique
  username String @unique

  // Auth & OAuth
  passwordHash    String?
  isEmailVerified Boolean @default(false)
  googleId        String? @unique

  // Profile JSONs
  publicInfo  Json? @default("{}")
  friendInfo  Json? @default("{}")
  privateInfo Json? @default("{}")
  preferences Json? @default("{}")

  avatarUrl        String?
  subscriptionTier SubscriptionTier @default(BASIC)
  tokenVersion     Int              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  playlists        Playlist[]             @relation("PlaylistOwner")
  collaborations   PlaylistCollaborator[]
  hostedEvents     Event[]                @relation("EventHost")
  eventInvites     EventInvite[]
  delegations      ControlDelegation[]    @relation("Delegatee")
  followers        Follows[]              @relation("Followers")
  following        Follows[]              @relation("Following")
  votes            Vote[]
  playlistTracks   PlaylistTrack[]
  eventTracksAdded EventTrack[]           @relation("EventTrackAddedBy")
  notifications    Notification[]
}

model Follows {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String?
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ======================================================
// 2. THE CENTRAL AUDIO DICTIONARY
// ======================================================
model Track {
  id String @id @default(uuid())

  providerTrackId String  @unique
  title           String
  artist          String?
  durationMs      Int
  thumbnailUrl    String?

  playlistTracks PlaylistTrack[]
  eventTracks    EventTrack[]
}

// ======================================================
// 3. FEATURE 3: PLAYLIST EDITOR
// ======================================================
model Playlist {
  id          String              @id @default(uuid())
  name        String
  visibility  Visibility          @default(PUBLIC)
  description String? // OPTIONAL text description
  tags        Tags[]              @default([]) // ARRAY of tags
  ownerId     String
  editLicense PlaylistEditLicense @default(OPEN)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // --- Relations ---
  owner         User                   @relation("PlaylistOwner", fields: [ownerId], references: [id])
  tracks        PlaylistTrack[]
  collaborators PlaylistCollaborator[] // Users licensed to co-edit if visibility is PRIVATE
  counter       PlaylistCounter? // For generating unique position values in a concurrent environment
}

model PlaylistTrack {
  id         String   @id @default(uuid())
  playlistId String
  trackId    String
  position   Int // Strict integer used for drag-and-drop ordering
  addedById  String // The user who added this specific track
  addedAt    DateTime @default(now())

  // --- Relations ---
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id]) // Link to the central Audio Dictionary
  addedBy  User     @relation(fields: [addedById], references: [id])

  // --- The Secret Sauce for Drag-and-Drop ---
  // This constraint guarantees that two tracks can NEVER occupy the exact same position
  // in the same playlist. This forces the PostgreSQL row-level locks to do their job!
  @@unique([playlistId, position])
  // Enforces that the exact same Track cannot be added multiple times to the same playlist.
  @@unique([playlistId, trackId])
}

model PlaylistCollaborator {
  id         String   @id @default(uuid())
  playlistId String
  userId     String
  grantedAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playlistId, userId])
}

model PlaylistCounter {
  playlistId   String @id
  nextPosition Int    @default(-1)

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

enum EventStatus {
  UPCOMING
  LIVE
  ENDED
}

// ======================================================
// 4. FEATURE 1: TRACK VOTE (Live Party Event)
// ======================================================
model Event {
  id String @id @default(uuid())

  // Event metadata
  name         String
  description  String?
  coverImage   String
  status       EventStatus @default(UPCOMING)
  visibility   Visibility  @default(PUBLIC)
  invitingOnly Boolean     @default(false)
  tags         Tags[]
  // hoster metadata
  hostId       String
  locationLat  Float?
  locationLng  Float?

  // Track
  playbackStatus           PlaybackStatus @default(PAUSED)
  currentTrackStartedAt    DateTime?
  pausedPlaybackPositionMs Int?
  currentTrackId           String?        @unique

  createdAt DateTime @default(now())
  startDate DateTime

  // Strict 1-to-1 Relation for currentTrackId
  host         User                @relation("EventHost", fields: [hostId], references: [id])
  currentTrack EventTrack?         @relation("EventCurrentTrack", fields: [currentTrackId], references: [id])
  tracks       EventTrack[]        @relation("EventTracks")
  invites      EventInvite[]
  policies     LicensePolicy[]
  delegations  ControlDelegation[]
}

model EventTrack {
  id String @id @default(uuid())

  eventId String
  event   Event  @relation("EventTracks", fields: [eventId], references: [id], onDelete: Cascade)

  trackId String
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Restrict)

  addedById String
  addedBy   User   @relation("EventTrackAddedBy", fields: [addedById], references: [id])

  voteScore Int         @default(0)
  status    TrackStatus @default(QUEUED)

  votes Vote[]

  // Back-relation for the 1-to-1 current track
  currentIn Event? @relation("EventCurrentTrack")

  @@unique([eventId, trackId])
}

model Vote {
  id           String   @id @default(uuid())
  eventTrackId String
  userId       String
  voteValue    Int // 1 (Upvote) or -1 (Downvote)
  createdAt    DateTime @default(now())

  eventTrack EventTrack @relation(fields: [eventTrackId], references: [id], onDelete: Cascade)

  // Mapped the relation to the User table for strict FK enforcement
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventTrackId, userId])
}

model EventInvite {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

enum PolicyType {
  GEOFENCE
  TIME_WINDOW
}

model LicensePolicy {
  id         String     @id @default(uuid())
  eventId    String
  policyType PolicyType
  config     Json

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ======================================================
// 5. FEATURE 2: CONTROL DELEGATION
// ======================================================
model ControlDelegation {
  id          String   @id @default(uuid())
  eventId     String
  delegateeId String
  deviceId    String
  isActive    Boolean  @default(true)
  grantedAt   DateTime @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  delegatee User  @relation("Delegatee", fields: [delegateeId], references: [id], onDelete: Cascade)

  @@unique([eventId, delegateeId, deviceId])
}

// ======================================================
// 6. NON-FUNCTIONAL REQUIREMENTS
// ======================================================
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String // Validated at app-level via AuditAction enum
  platform    String
  deviceModel String
  deviceId    String
  appVersion  String
  metadata    Json?    @default("{}") // Action-specific context (trackId, playlistId, etc.)
  ipAddress   String? // For security auditing
  timestamp   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}
