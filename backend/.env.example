# ─── API ────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=music_room
DATABASE_URL=postgresql://admin:admin123@postgres:5432/music_room?schema=public

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── pgAdmin ────────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@music-room.com
PGADMIN_DEFAULT_PASSWORD=admin123

# ─── Prisma ────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://admin:rootpassword@postgres:5432/music_room?schema=public"

# If you want to connect to the database from your host machine, use this URL instead:
# DATABASE_URL="postgresql://admin:rootpassword@localhost:5432/music_room?schema=public"
