# ─── API ────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=super-secret-dev-key-change-in-production

# ─── PostgreSQL ─────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=music_room

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=localhost # Use 'redis' if running in Docker, 'localhost' if running locally
REDIS_PORT=6379

# ─── SMTP (only required in production) ─────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@music-room.com

# ─── pgAdmin ────────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@music-room.com
PGADMIN_DEFAULT_PASSWORD=admin123

# ─── Prisma ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# If you want to connect to the database from within the Docker container, use this URL:
# DATABASE_URL="postgresql://admin:admin123@postgres:5432/music_room?schema=public"

# Connect to the database from your host machine
DATABASE_URL="postgresql://admin:admin123@localhost:5432/music_room?schema=public"