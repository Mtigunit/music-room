generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ======================================================
// ENUMS
// ======================================================
enum PlaybackStatus {
  STOPPED
  PLAYING
  PAUSED
}

enum TrackStatus {
  QUEUED
  PLAYING
  PLAYED
}

// ======================================================
// 1. USER MANAGEMENT & SOCIAL
// ======================================================
model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String    @unique

  // Auth & OAuth
  passwordHash         String?
  isEmailVerified      Boolean   @default(false)
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  googleId             String?   @unique
  facebookId           String?   @unique

  // Subject Requirement: Profile data MUST be JSON
  publicInfo           Json?     @default("{}")
  friendInfo           Json?     @default("{}")
  privateInfo          Json?     @default("{}")
  preferences          Json?     @default("{}")

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relationships
  playlists            Playlist[]             @relation("PlaylistOwner")
  collaborations       PlaylistCollaborator[]
  hostedEvents         Event[]                @relation("EventHost")
  eventInvites         EventInvite[]
  delegations          ControlDelegation[]    @relation("Delegatee")
  friendshipsInitiated Friendship[]           @relation("UserOne")
  friendshipsReceived  Friendship[]           @relation("UserTwo")
}

model Friendship {
  id        String   @id @default(uuid())
  userOneId String
  userTwoId String
  status    String   @default("pending") // "pending", "accepted", "blocked"
  createdAt DateTime @default(now())

  userOne   User     @relation("UserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo   User     @relation("UserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)

  @@unique([userOneId, userTwoId])
}

// ======================================================
// 2. THE CENTRAL AUDIO DICTIONARY (Normalization)
// ======================================================
model Track {
  id              String   @id @default(uuid())

  // Audio Provider Data (YouTube API)
  providerTrackId String   @unique // e.g., "dQw4w9WgXcQ"
  title           String
  artist          String?
  durationMs      Int
  thumbnailUrl    String?

  // Relations out to the features
  playlistTracks  PlaylistTrack[]
  eventTracks     EventTrack[]
}

// ======================================================
// 3. FEATURE 3: PLAYLIST EDITOR (Creation / Radio)
// ======================================================
model Playlist {
  id          String   @id @default(uuid())
  name        String
  ownerId     String
  owner       User     @relation("PlaylistOwner", fields: [ownerId], references: [id])
  visibility  String   @default("public") // "public" or "private"

  // Playback State (For Radio Station Mode)
  playbackStatus           PlaybackStatus @default(STOPPED)
  currentTrackId           String?
  currentTrackStartedAt    DateTime?
  pausedPlaybackPositionMs Int?

  tracks        PlaylistTrack[]
  collaborators PlaylistCollaborator[]
  createdAt     DateTime @default(now())
}

model PlaylistTrack {
  id              String      @id @default(uuid())

  playlistId      String
  playlist        Playlist    @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  trackId         String
  track           Track       @relation(fields: [trackId], references: [id], onDelete: Restrict)

  // Editor Rule: Drag-and-Drop Indexing
  position        Int
  status          TrackStatus @default(QUEUED)
}

// License Requirement: "Licensed to specific users"
model PlaylistCollaborator {
  id          String   @id @default(uuid())
  playlistId  String
  userId      String
  grantedAt   DateTime @default(now())

  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playlistId, userId])
}

// ======================================================
// 4. FEATURE 1: TRACK VOTE (Live Party Event)
// ======================================================
model Event {
  id          String   @id @default(uuid())
  name        String
  hostId      String
  host        User     @relation("EventHost", fields: [hostId], references: [id])
  status      String   @default("active") // "active", "ended"
  visibility  String   @default("public") // "public", "private"

  // Playback State (For Live Party UI Sync)
  playbackStatus           PlaybackStatus @default(STOPPED)
  currentTrackId           String?
  currentTrackStartedAt    DateTime?
  pausedPlaybackPositionMs Int?

  tracks       EventTrack[]
  invites      EventInvite[]
  policies     LicensePolicy[]
  delegations  ControlDelegation[]
  createdAt    DateTime @default(now())
}

model EventTrack {
  id              String      @id @default(uuid())

  eventId         String
  event           Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  trackId         String
  track           Track       @relation(fields: [trackId], references: [id], onDelete: Restrict)

  // Voting Rule: Democratic Sorting & Soft Deletes
  voteScore       Int         @default(0)
  status          TrackStatus @default(QUEUED)

  votes           Vote[]
}

model Vote {
  id           String      @id @default(uuid())
  eventTrackId String
  userId       String
  voteValue    Int         // 1 (Upvote) or -1 (Downvote)
  createdAt    DateTime    @default(now())

  eventTrack   EventTrack  @relation(fields: [eventTrackId], references: [id], onDelete: Cascade)

  @@unique([eventTrackId, userId])
}

// License Requirement: "Invited users are the only ones who can find the event"
model EventInvite {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  status    String   @default("pending") // "pending", "accepted", "declined"
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

// License Requirement: "Licensed to specific place/time"
model LicensePolicy {
  id         String   @id @default(uuid())
  eventId    String
  policyType String   // "geofence", "time_window"
  config     Json     // Stores coordinates or timestamp ranges

  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ======================================================
// 5. FEATURE 2: CONTROL DELEGATION (Passing the Aux)
// ======================================================
// License Requirement: "Licensed device specifically"
model ControlDelegation {
  id          String   @id @default(uuid())
  eventId     String
  delegateeId String
  deviceId    String   // CRITICAL: The unique hardware ID
  isActive    Boolean  @default(true)
  grantedAt   DateTime @default(now())

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  delegatee   User     @relation("Delegatee", fields: [delegateeId], references: [id], onDelete: Cascade)

  @@unique([eventId, delegateeId, deviceId])
}

// ======================================================
// 6. NON-FUNCTIONAL REQUIREMENTS
// ======================================================
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String   // e.g., "USER_LOGIN", "TRACK_MOVED", "VOTE_CAST"
  platform    String   // "iOS", "Android", "Web"
  deviceModel String
  appVersion  String
  timestamp   DateTime @default(now())
}